{
    "name": "cluar5-dev",
    "build": {
        "dockerfile": "../workshop/docker/Dockerfile.dev",
        "context": ".."
    },
    "workspaceFolder": "/app",
    "remoteUser": "appuser",
    "remoteEnv": {
        "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
    },

    // Runs once on first container creation — detects a fresh template clone
    // and runs the rename wizard if needed.
    "onCreateCommand": "bash workshop/scripts/rename.sh",

    // Keep the container running when the VS Code window closes — preserves
    // live Gambit REPL state so you can reconnect without losing your session.
    "shutdownAction": "none",

    "customizations": {
        "vscode": {
            "extensions": [
                // C/C++
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                // Lua
                "sumneko.lua",
                // Git
                "eamodio.gitlens"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "editor.formatOnSave": false,
                "files.trimTrailingWhitespace": true,
                "C_Cpp.default.compilerPath": "/usr/bin/gcc",
                "C_Cpp.default.includePath": [
                    "${workspaceFolder}/c",
                    "/usr/include/luajit-2.1"
                ]
            }
        }
    },

    // Gambit REPL port — connect with: rlwrap nc localhost 7000
    "forwardPorts": [7000],
    "portsAttributes": {
        "7000": {
            "label": "Gambit REPL",
            "onAutoForward": "silent"
        }
    }
}
